<Window x:Class="StockInvoiceApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="{DynamicResource AppTitle}" Height="900" Width="1400" MinHeight="780" MinWidth="1220">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="{DynamicResource AppTitle}" FontSize="22" FontWeight="SemiBold" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="btnLangTh" Content="ไทย" Width="60" Margin="0,0,4,0" Click="BtnLangTh_Click" />
                <Button x:Name="btnLangEn" Content="EN" Width="60" Click="BtnLangEn_Click" />
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="{DynamicResource Dashboard}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="220" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="{DynamicResource BusinessSnapshot}" FontSize="18" FontWeight="SemiBold" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource From}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <DatePicker x:Name="dpDashFrom" Width="130" Margin="0,0,8,0" />
                            <TextBlock Text="{DynamicResource To}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <DatePicker x:Name="dpDashTo" Width="130" Margin="0,0,8,0" />
                            <TextBlock Text="{DynamicResource LowStock}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox x:Name="txtLowStockThreshold" Width="60" Text="10" Margin="0,0,8,0" ToolTip="จำนวนสินค้าคงเหลือต่ำสุดที่ต้องการแจ้งเตือน / Low stock threshold" />
                            <Button Content="{DynamicResource Apply}" Width="110" Margin="0,0,8,0" Click="RefreshDashboard_Click" />
                            <Button Content="{DynamicResource ExportPDF}" Width="100" Margin="0,0,8,0" Click="ExportDashboardPdf_Click" />
                            <Button Content="{DynamicResource Clear}" Width="100" Click="ClearDashboardFilter_Click" />
                        </StackPanel>
                    </DockPanel>

                    <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,10">
                        <Border BorderBrush="#DADADA" BorderThickness="1" Margin="0,0,8,0" Padding="10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Products}" FontWeight="SemiBold" />
                                <TextBlock x:Name="txtTotalProducts" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="{DynamicResource TotalStockQty}" />
                                <TextBlock x:Name="txtTotalStockQty" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#DADADA" BorderThickness="1" Margin="0,0,8,0" Padding="10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Customers}" FontWeight="SemiBold" />
                                <TextBlock x:Name="txtTotalCustomers" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="{DynamicResource Invoices}" />
                                <TextBlock x:Name="txtTotalInvoices" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#DADADA" BorderThickness="1" Margin="0,0,8,0" Padding="10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SalesToday}" FontWeight="SemiBold" />
                                <TextBlock x:Name="txtSalesDaily" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="{DynamicResource SalesThisMonth}" />
                                <TextBlock x:Name="txtSalesMonthly" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#DADADA" BorderThickness="1" Padding="10">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource SalesThisYear}" FontWeight="SemiBold" />
                                <TextBlock x:Name="txtSalesYearly" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="{DynamicResource TaxRateLowStock}" />
                                <TextBlock x:Name="txtTaxRateHint" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <GroupBox Header="{DynamicResource SalesLast7Days}">
                            <oxy:PlotView x:Name="plotDailySales" />
                        </GroupBox>
                        <GroupBox Grid.Column="1" Header="{DynamicResource SalesLast12Months}" Margin="8,0,0,0">
                            <oxy:PlotView x:Name="plotMonthlySales" />
                        </GroupBox>
                    </Grid>

                    <GroupBox Grid.Row="3" Header="{DynamicResource StockLevelsLowToHigh}">
                        <DataGrid x:Name="dgStockLevels" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                            <Setter Property="Background" Value="#FFF1D6D6" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource ProductID}" Binding="{Binding ProductId}" Width="90" />
                                <DataGridTextColumn Header="{DynamicResource SKU}" Binding="{Binding Sku}" Width="130" />
                                <DataGridTextColumn Header="{DynamicResource Name}" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource StockQty}" Binding="{Binding StockQty, StringFormat=N2}" Width="120" />
                                <DataGridTextColumn Header="{DynamicResource SellPrice}" Binding="{Binding SellPrice, StringFormat=N2}" Width="120" />
                                <DataGridCheckBoxColumn Header="{DynamicResource Low}" Binding="{Binding IsLowStock}" Width="70" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource InvoiceCRUD}">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="{DynamicResource Invoices}" Grid.Column="0" Margin="0,0,8,0">
                        <DockPanel Margin="8">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
                                <Button Content="{DynamicResource Reload}" Width="90" Margin="0,0,8,0" Click="ReloadInvoices_Click" />
                                <Button Content="{DynamicResource New}" Width="90" Margin="0,0,8,0" Click="NewInvoice_Click" />
                                <Button x:Name="btnDeleteInvoice" Content="{DynamicResource Delete}" Width="90" Margin="0,0,8,0" Click="DeleteInvoice_Click" />
                                <Button Content="{DynamicResource ExportInvoicePDF}" Width="140" Click="ExportInvoicePdf_Click" />
                            </StackPanel>
                            <DataGrid x:Name="dgInvoices" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgInvoices_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource ID}" Binding="{Binding Id}" Width="60" />
                                    <DataGridTextColumn Header="{DynamicResource InvoiceNo}" Binding="{Binding InvoiceNo}" Width="140" />
                                    <DataGridTextColumn Header="{DynamicResource Customer}" Binding="{Binding CustomerName}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource Date}" Binding="{Binding InvoiceDate, StringFormat=yyyy-MM-dd}" Width="110" />
                                    <DataGridTextColumn Header="{DynamicResource Total}" Binding="{Binding GrandTotal, StringFormat=N2}" Width="100" />
                                    <DataGridTextColumn Header="{DynamicResource Status}" Binding="{Binding Status}" Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Header="{DynamicResource InvoiceEditor}" Grid.Column="1">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="txtInvoiceLockStatus" Grid.Row="0" Grid.ColumnSpan="4" Foreground="#B91C1C" FontWeight="Bold" Margin="0,0,0,6" />

                            <TextBlock Text="{DynamicResource InvoiceNo}" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                            <TextBox x:Name="txtInvoiceNo" Grid.Row="1" Grid.Column="1" Margin="0,0,8,6" ToolTip="เลขที่ใบกำกับ / Invoice No" />
                            <TextBlock Text="{DynamicResource Status}" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" />
                            <ComboBox x:Name="cbStatus" Grid.Row="1" Grid.Column="3" Margin="0,0,0,6" />

                            <TextBlock Text="{DynamicResource Customer}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                            <ComboBox x:Name="cbCustomer" Grid.Row="2" Grid.Column="1" Margin="0,0,8,6" DisplayMemberPath="Name" SelectedValuePath="Id" />
                            <TextBlock Text="{DynamicResource InvoiceDate}" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" />
                            <DatePicker x:Name="dpInvoiceDate" Grid.Row="2" Grid.Column="3" Margin="0,0,0,6" />

                            <TextBlock Text="{DynamicResource DueDate}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" />
                            <DatePicker x:Name="dpDueDate" Grid.Row="3" Grid.Column="1" Margin="0,0,8,6" />
                            <TextBlock Text="{DynamicResource Notes}" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" />
                            <TextBox x:Name="txtNotes" Grid.Row="3" Grid.Column="3" Margin="0,0,0,6" ToolTip="หมายเหตุ / Notes" />

                            <GroupBox Grid.Row="4" Grid.ColumnSpan="4" Header="{DynamicResource InvoiceDynamicFields}" Margin="0,0,0,8">
                                <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="spInvoiceDynamicFields" Margin="8,4,8,8" />
                                </ScrollViewer>
                            </GroupBox>

                            <Border Grid.Row="5" Grid.ColumnSpan="4" BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.2*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="cbItemProduct" Grid.Column="0" Margin="0,0,8,0" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="CbItemProduct_SelectionChanged" />
                                        <TextBox x:Name="txtItemQty" Grid.Column="1" Margin="0,0,8,0" Text="1" ToolTip="จำนวน / Quantity" />
                                        <TextBox x:Name="txtItemUnitPrice" Grid.Column="2" Margin="0,0,8,0" Text="0" ToolTip="ราคาต่อหน่วย / Unit Price" />
                                        <TextBox x:Name="txtItemDiscount" Grid.Column="3" Margin="0,0,8,0" Text="0" ToolTip="ส่วนลด / Discount" />
                                        <Button x:Name="btnAddLine" Content="{DynamicResource AddLine}" Grid.Column="4" Width="100" Click="AddLine_Click" />
                                    </Grid>

                                    <DataGrid x:Name="dgItems" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="{DynamicResource Product}" Binding="{Binding ProductDisplay}" Width="*" />
                                            <DataGridTextColumn Header="{DynamicResource Qty}" Binding="{Binding Qty, StringFormat=N2}" Width="100" />
                                            <DataGridTextColumn Header="{DynamicResource UnitPrice}" Binding="{Binding UnitPrice, StringFormat=N2}" Width="110" />
                                            <DataGridTextColumn Header="{DynamicResource Discount}" Binding="{Binding Discount, StringFormat=N2}" Width="100" />
                                            <DataGridTextColumn Header="{DynamicResource LineTotal}" Binding="{Binding LineTotal, StringFormat=N2}" Width="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="6" Grid.ColumnSpan="4" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="btnRemoveLine" Grid.Column="0" Content="{DynamicResource RemoveSelectedLine}" Width="160" Margin="0,0,8,0" Click="RemoveLine_Click" />
                                <Button x:Name="btnSaveInvoice" Grid.Column="1" Content="{DynamicResource SaveInvoice}" Width="110" Margin="0,0,8,0" Click="SaveInvoice_Click" />

                                <TextBlock Grid.Column="3" Text="{DynamicResource Subtotal}" VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBlock x:Name="txtSubtotal" Grid.Column="4" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="5" Text="{DynamicResource Tax}" VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBlock x:Name="txtTax" Grid.Column="6" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="7" Text="{DynamicResource Grand}" VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBlock x:Name="txtGrand" Grid.Column="8" VerticalAlignment="Center" FontWeight="Bold" FontSize="15" />
                            </Grid>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource MasterData}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="{DynamicResource Products}" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DataGrid x:Name="dgManageProducts" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="DgManageProducts_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource ID}" Binding="{Binding Id}" Width="60" />
                                    <DataGridTextColumn Header="{DynamicResource SKU}" Binding="{Binding Sku}" Width="120" />
                                    <DataGridTextColumn Header="{DynamicResource Name}" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource StockQty}" Binding="{Binding StockQty, StringFormat=N2}" Width="90" />
                                    <DataGridCheckBoxColumn Header="{DynamicResource Active}" Binding="{Binding IsActive}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                <WrapPanel Margin="0,0,0,6">
                                    <TextBox x:Name="txtProdSku" Width="110" Margin="0,0,6,0" ToolTip="รหัสสินค้า / SKU" />
                                    <TextBox x:Name="txtProdName" Width="220" Margin="0,0,6,0" ToolTip="ชื่อสินค้า / Product Name" />
                                    <TextBox x:Name="txtProdUnit" Width="70" Margin="0,0,6,0" Text="pcs" ToolTip="หน่วยนับ / Unit" />
                                    <TextBox x:Name="txtProdSellPrice" Width="90" Margin="0,0,6,0" Text="0" ToolTip="ราคาขาย / Sell Price" />
                                    <TextBox x:Name="txtProdCostPrice" Width="90" Margin="0,0,6,0" Text="0" ToolTip="ราคาทุน / Cost Price" />
                                    <TextBox x:Name="txtProdTaxRate" Width="70" Margin="0,0,6,0" Text="7" ToolTip="ภาษี (%) / Tax Rate" />
                                    <CheckBox x:Name="chkProdActive" Content="Active" IsChecked="True" VerticalAlignment="Center" />
                                </WrapPanel>
                                <GroupBox Header="Product Dynamic Fields" Margin="0,0,0,6">
                                    <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="spProductDynamicFields" Margin="8,4,8,8" />
                                    </ScrollViewer>
                                </GroupBox>
                                <WrapPanel>
                                    <Button Content="{DynamicResource New}" Width="90" Margin="0,0,8,0" Click="NewProduct_Click" />
                                    <Button Content="{DynamicResource Save}" Width="90" Margin="0,0,8,0" Click="SaveProduct_Click" />
                                    <Button Content="{DynamicResource Delete}" Width="90" Click="DeleteProduct_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="{DynamicResource Customers}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DataGrid x:Name="dgManageCustomers" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="DgManageCustomers_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource ID}" Binding="{Binding Id}" Width="60" />
                                    <DataGridTextColumn Header="{DynamicResource Code}" Binding="{Binding Code}" Width="120" />
                                    <DataGridTextColumn Header="{DynamicResource Name}" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource Phone}" Binding="{Binding Phone}" Width="120" />
                                    <DataGridCheckBoxColumn Header="{DynamicResource Active}" Binding="{Binding IsActive}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                <WrapPanel Margin="0,0,0,6">
                                    <TextBox x:Name="txtCustCode" Width="110" Margin="0,0,6,0" ToolTip="รหัสลูกค้า / Customer Code" />
                                    <TextBox x:Name="txtCustName" Width="180" Margin="0,0,6,0" ToolTip="ชื่อลูกค้า / Customer Name" />
                                    <TextBox x:Name="txtCustTaxId" Width="120" Margin="0,0,6,0" ToolTip="เลขประจำตัวผู้เสียภาษี / Tax ID" />
                                    <TextBox x:Name="txtCustPhone" Width="110" Margin="0,0,6,0" ToolTip="เบอร์โทร / Phone" />
                                    <TextBox x:Name="txtCustEmail" Width="150" Margin="0,0,6,0" ToolTip="อีเมล / Email" />
                                </WrapPanel>
                                <WrapPanel Margin="0,0,0,6">
                                    <TextBox x:Name="txtCustAddress" Width="430" Margin="0,0,6,0" ToolTip="ที่อยู่ / Address" />
                                    <CheckBox x:Name="chkCustActive" Content="Active" IsChecked="True" VerticalAlignment="Center" />
                                </WrapPanel>
                                <GroupBox Header="Customer Dynamic Fields" Margin="0,0,0,6">
                                    <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="spCustomerDynamicFields" Margin="8,4,8,8" />
                                    </ScrollViewer>
                                </GroupBox>
                                <WrapPanel>
                                    <Button Content="{DynamicResource New}" Width="90" Margin="0,0,8,0" Click="NewCustomer_Click" />
                                    <Button Content="{DynamicResource Save}" Width="90" Margin="0,0,8,0" Click="SaveCustomer_Click" />
                                    <Button Content="{DynamicResource Delete}" Width="90" Click="DeleteCustomer_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="{DynamicResource StockAdjustment}" Grid.Row="2" Grid.ColumnSpan="2">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="cbAdjustProduct" Grid.Column="0" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1" Text="{DynamicResource QtyAdjust}" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox x:Name="txtAdjustQty" Grid.Column="2" Width="90" Margin="0,0,8,0" Text="0" ToolTip="จำนวนที่ปรับ / Adjust Qty" />
                            <TextBox x:Name="txtAdjustUnitCost" Grid.Column="3" Width="100" Margin="0,0,8,0" Text="0" ToolTip="ต้นทุนต่อหน่วย / Unit Cost" />
                            <TextBox x:Name="txtAdjustNote" Grid.Column="4" Margin="0,0,8,0" ToolTip="หมายเหตุ / Note" />
                            <Button Grid.Column="5" Width="120" Content="{DynamicResource AdjustStock}" Click="AdjustStock_Click" />
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource ImportCSV}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border BorderThickness="1" BorderBrush="#DDD" Padding="10" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource ProductsCSVColumns}" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Button Content="{DynamicResource ImportProductsCSV}" Width="180" Click="ImportProducts_Click" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" BorderThickness="1" BorderBrush="#DDD" Padding="10" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource CustomersCSVColumns}" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Button Content="{DynamicResource ImportCustomersCSV}" Width="180" Click="ImportCustomers_Click" />
                        </StackPanel>
                    </Border>

                    <GroupBox Grid.Row="2" Header="{DynamicResource ImportLog}">
                        <TextBox x:Name="txtImportLog" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" />
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="{DynamicResource Settings}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <GroupBox Header="{DynamicResource DynamicFields}">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <WrapPanel Margin="0,0,0,8">
                                <TextBlock Text="{DynamicResource Entity}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <ComboBox x:Name="cbDynamicEntity" Width="140" Margin="0,0,8,0" SelectionChanged="CbDynamicEntity_SelectionChanged" />
                                <Button Content="{DynamicResource Reload}" Width="90" Margin="0,0,8,0" Click="ReloadDynamicFields_Click" />
                                <Button Content="{DynamicResource New}" Width="90" Margin="0,0,8,0" Click="NewDynamicField_Click" />
                                <Button Content="{DynamicResource SaveField}" Width="100" Margin="0,0,8,0" Click="SaveDynamicField_Click" />
                                <Button Content="{DynamicResource DeleteField}" Width="100" Click="DeleteDynamicField_Click" />
                            </WrapPanel>

                            <DataGrid x:Name="dgDynamicFields" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="DgDynamicFields_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource ID}" Binding="{Binding Id}" Width="60" />
                                    <DataGridTextColumn Header="{DynamicResource Key}" Binding="{Binding FieldKey}" Width="150" />
                                    <DataGridTextColumn Header="{DynamicResource Label}" Binding="{Binding Label}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource Type}" Binding="{Binding DataType}" Width="90" />
                                    <DataGridCheckBoxColumn Header="{DynamicResource Req}" Binding="{Binding IsRequired}" Width="60" />
                                    <DataGridCheckBoxColumn Header="{DynamicResource Visible}" Binding="{Binding IsVisible}" Width="70" />
                                    <DataGridCheckBoxColumn Header="{DynamicResource PDF}" Binding="{Binding ShowInPdf}" Width="60" />
                                    <DataGridTextColumn Header="{DynamicResource Sort}" Binding="{Binding SortOrder}" Width="80" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                                <TextBox x:Name="txtDynKey" Width="150" Margin="0,0,6,0" ToolTip="ชื่อคีย์ (อังกฤษ) / Field Key (EN)" />
                                <TextBox x:Name="txtDynLabel" Width="220" Margin="0,0,6,0" ToolTip="ชื่อฟิลด์ที่แสดง / Field Label" />
                                <ComboBox x:Name="cbDynDataType" Width="110" Margin="0,0,6,0" />
                                <TextBox x:Name="txtDynSort" Width="70" Margin="0,0,6,0" Text="0" />
                                <CheckBox x:Name="chkDynRequired" Content="Required" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <CheckBox x:Name="chkDynVisible" Content="Visible" IsChecked="True" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <CheckBox x:Name="chkDynPdf" Content="Show in PDF" VerticalAlignment="Center" />
                            </WrapPanel>
                        </Grid>
                    </GroupBox>

                    <Separator Grid.Row="1" Margin="0,10" />

                    <GroupBox Grid.Row="2" Header="Backup and Reset">
                        <StackPanel Orientation="Horizontal" Margin="8">
                                <Button Content="{DynamicResource ExportBackupJSON}" Width="170" Margin="0,0,8,0" Click="ExportBackup_Click" />
                                <Button Content="{DynamicResource ImportBackupJSON}" Width="170" Margin="0,0,8,0" Click="ImportBackup_Click" />
                                <Button Content="{DynamicResource HardReset}" Width="200" Click="HardReset_Click" />
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
