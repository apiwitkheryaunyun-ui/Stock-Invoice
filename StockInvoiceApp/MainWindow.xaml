<Window x:Class="StockInvoiceApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"
        mc:Ignorable="d"
        Title="Stock &amp; Invoice Starter" Height="900" Width="1400" MinHeight="780" MinWidth="1220">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Stock &amp; Invoice Starter" FontSize="22" FontWeight="SemiBold" />
            <TextBlock x:Name="txtMode" DockPanel.Dock="Right" VerticalAlignment="Center" FontWeight="Bold" />
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Dashboard">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="220" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Business Snapshot" FontSize="18" FontWeight="SemiBold" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock Text="From" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <DatePicker x:Name="dpDashFrom" Width="130" Margin="0,0,8,0" />
                            <TextBlock Text="To" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <DatePicker x:Name="dpDashTo" Width="130" Margin="0,0,8,0" />
                            <TextBlock Text="Low Stock &lt;" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox x:Name="txtLowStockThreshold" Width="60" Text="10" Margin="0,0,8,0" />
                            <Button Content="Apply Filter" Width="110" Margin="0,0,8,0" Click="RefreshDashboard_Click" />
                            <Button Content="Export PDF" Width="100" Margin="0,0,8,0" Click="ExportDashboardPdf_Click" />
                            <Button Content="Clear Filter" Width="100" Click="ClearDashboardFilter_Click" />
                        </StackPanel>
                    </DockPanel>

                    <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,10">
                        <Border BorderBrush="#DADADA" BorderThickness="1" Margin="0,0,8,0" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Products" FontWeight="SemiBold" />
                                <TextBlock x:Name="txtTotalProducts" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="Total stock qty" />
                                <TextBlock x:Name="txtTotalStockQty" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#DADADA" BorderThickness="1" Margin="0,0,8,0" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Customers" FontWeight="SemiBold" />
                                <TextBlock x:Name="txtTotalCustomers" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="Invoices" />
                                <TextBlock x:Name="txtTotalInvoices" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#DADADA" BorderThickness="1" Margin="0,0,8,0" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Sales Today" FontWeight="SemiBold" />
                                <TextBlock x:Name="txtSalesDaily" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="Sales This Month" />
                                <TextBlock x:Name="txtSalesMonthly" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="#DADADA" BorderThickness="1" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Sales This Year" FontWeight="SemiBold" />
                                <TextBlock x:Name="txtSalesYearly" FontSize="24" FontWeight="Bold" />
                                <TextBlock Text="Tax Rate / Low Stock" />
                                <TextBlock x:Name="txtTaxRateHint" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <GroupBox Header="Sales: Last 7 Days">
                            <oxy:PlotView x:Name="plotDailySales" />
                        </GroupBox>
                        <GroupBox Grid.Column="1" Header="Sales: Last 12 Months" Margin="8,0,0,0">
                            <oxy:PlotView x:Name="plotMonthlySales" />
                        </GroupBox>
                    </Grid>

                    <GroupBox Grid.Row="3" Header="Stock Levels (low to high)">
                        <DataGrid x:Name="dgStockLevels" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                            <Setter Property="Background" Value="#FFF1D6D6" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" Width="90" />
                                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="130" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                <DataGridTextColumn Header="Stock Qty" Binding="{Binding StockQty, StringFormat=N2}" Width="120" />
                                <DataGridTextColumn Header="Sell Price" Binding="{Binding SellPrice, StringFormat=N2}" Width="120" />
                                <DataGridCheckBoxColumn Header="Low" Binding="{Binding IsLowStock}" Width="70" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Invoice CRUD">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Invoices" Grid.Column="0" Margin="0,0,8,0">
                        <DockPanel Margin="8">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
                                <Button Content="Reload" Width="90" Margin="0,0,8,0" Click="ReloadInvoices_Click" />
                                <Button Content="New" Width="90" Margin="0,0,8,0" Click="NewInvoice_Click" />
                                <Button x:Name="btnDeleteInvoice" Content="Delete" Width="90" Margin="0,0,8,0" Click="DeleteInvoice_Click" />
                                <Button Content="Export Invoice PDF" Width="140" Click="ExportInvoicePdf_Click" />
                            </StackPanel>
                            <DataGrid x:Name="dgInvoices" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" SelectionChanged="DgInvoices_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                                    <DataGridTextColumn Header="Invoice No" Binding="{Binding InvoiceNo}" Width="140" />
                                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*" />
                                    <DataGridTextColumn Header="Date" Binding="{Binding InvoiceDate, StringFormat=yyyy-MM-dd}" Width="110" />
                                    <DataGridTextColumn Header="Total" Binding="{Binding GrandTotal, StringFormat=N2}" Width="100" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Header="Invoice Editor" Grid.Column="1">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="txtInvoiceLockStatus" Grid.Row="0" Grid.ColumnSpan="4" Foreground="#B91C1C" FontWeight="Bold" Margin="0,0,0,6" />

                            <TextBlock Text="Invoice No" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" />
                            <TextBox x:Name="txtInvoiceNo" Grid.Row="1" Grid.Column="1" Margin="0,0,8,6" />
                            <TextBlock Text="Status" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" />
                            <ComboBox x:Name="cbStatus" Grid.Row="1" Grid.Column="3" Margin="0,0,0,6" />

                            <TextBlock Text="Customer" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" />
                            <ComboBox x:Name="cbCustomer" Grid.Row="2" Grid.Column="1" Margin="0,0,8,6" DisplayMemberPath="Name" SelectedValuePath="Id" />
                            <TextBlock Text="Invoice Date" Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" />
                            <DatePicker x:Name="dpInvoiceDate" Grid.Row="2" Grid.Column="3" Margin="0,0,0,6" />

                            <TextBlock Text="Due Date" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" />
                            <DatePicker x:Name="dpDueDate" Grid.Row="3" Grid.Column="1" Margin="0,0,8,6" />
                            <TextBlock Text="Notes" Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" />
                            <TextBox x:Name="txtNotes" Grid.Row="3" Grid.Column="3" Margin="0,0,0,6" />

                            <GroupBox Grid.Row="4" Grid.ColumnSpan="4" Header="Invoice Dynamic Fields" Margin="0,0,0,8">
                                <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="spInvoiceDynamicFields" Margin="8,4,8,8" />
                                </ScrollViewer>
                            </GroupBox>

                            <Border Grid.Row="5" Grid.ColumnSpan="4" BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.2*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="cbItemProduct" Grid.Column="0" Margin="0,0,8,0" DisplayMemberPath="Name" SelectedValuePath="Id" SelectionChanged="CbItemProduct_SelectionChanged" />
                                        <TextBox x:Name="txtItemQty" Grid.Column="1" Margin="0,0,8,0" Text="1" />
                                        <TextBox x:Name="txtItemUnitPrice" Grid.Column="2" Margin="0,0,8,0" Text="0" />
                                        <TextBox x:Name="txtItemDiscount" Grid.Column="3" Margin="0,0,8,0" Text="0" />
                                        <Button x:Name="btnAddLine" Content="Add Line" Grid.Column="4" Width="100" Click="AddLine_Click" />
                                    </Grid>

                                    <DataGrid x:Name="dgItems" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Product" Binding="{Binding ProductDisplay}" Width="*" />
                                            <DataGridTextColumn Header="Qty" Binding="{Binding Qty, StringFormat=N2}" Width="100" />
                                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="110" />
                                            <DataGridTextColumn Header="Discount" Binding="{Binding Discount, StringFormat=N2}" Width="100" />
                                            <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat=N2}" Width="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="6" Grid.ColumnSpan="4" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="btnRemoveLine" Grid.Column="0" Content="Remove Selected Line" Width="160" Margin="0,0,8,0" Click="RemoveLine_Click" />
                                <Button x:Name="btnSaveInvoice" Grid.Column="1" Content="Save Invoice" Width="110" Margin="0,0,8,0" Click="SaveInvoice_Click" />

                                <TextBlock Grid.Column="3" Text="Subtotal:" VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBlock x:Name="txtSubtotal" Grid.Column="4" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="5" Text="Tax:" VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBlock x:Name="txtTax" Grid.Column="6" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="7" Text="Grand:" VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBlock x:Name="txtGrand" Grid.Column="8" VerticalAlignment="Center" FontWeight="Bold" FontSize="15" />
                            </Grid>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Master Data">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Products" Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DataGrid x:Name="dgManageProducts" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="DgManageProducts_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                                    <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="120" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Stock" Binding="{Binding StockQty, StringFormat=N2}" Width="90" />
                                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                <WrapPanel Margin="0,0,0,6">
                                    <TextBox x:Name="txtProdSku" Width="110" Margin="0,0,6,0" />
                                    <TextBox x:Name="txtProdName" Width="220" Margin="0,0,6,0" />
                                    <TextBox x:Name="txtProdUnit" Width="70" Margin="0,0,6,0" Text="pcs" />
                                    <TextBox x:Name="txtProdSellPrice" Width="90" Margin="0,0,6,0" Text="0" />
                                    <TextBox x:Name="txtProdCostPrice" Width="90" Margin="0,0,6,0" Text="0" />
                                    <TextBox x:Name="txtProdTaxRate" Width="70" Margin="0,0,6,0" Text="7" />
                                    <CheckBox x:Name="chkProdActive" Content="Active" IsChecked="True" VerticalAlignment="Center" />
                                </WrapPanel>
                                <GroupBox Header="Product Dynamic Fields" Margin="0,0,0,6">
                                    <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="spProductDynamicFields" Margin="8,4,8,8" />
                                    </ScrollViewer>
                                </GroupBox>
                                <WrapPanel>
                                    <Button Content="New" Width="90" Margin="0,0,8,0" Click="NewProduct_Click" />
                                    <Button Content="Save" Width="90" Margin="0,0,8,0" Click="SaveProduct_Click" />
                                    <Button Content="Delete" Width="90" Click="DeleteProduct_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Customers" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DataGrid x:Name="dgManageCustomers" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="DgManageCustomers_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                                    <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="120" />
                                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                <WrapPanel Margin="0,0,0,6">
                                    <TextBox x:Name="txtCustCode" Width="110" Margin="0,0,6,0" />
                                    <TextBox x:Name="txtCustName" Width="180" Margin="0,0,6,0" />
                                    <TextBox x:Name="txtCustTaxId" Width="120" Margin="0,0,6,0" />
                                    <TextBox x:Name="txtCustPhone" Width="110" Margin="0,0,6,0" />
                                    <TextBox x:Name="txtCustEmail" Width="150" Margin="0,0,6,0" />
                                </WrapPanel>
                                <WrapPanel Margin="0,0,0,6">
                                    <TextBox x:Name="txtCustAddress" Width="430" Margin="0,0,6,0" />
                                    <CheckBox x:Name="chkCustActive" Content="Active" IsChecked="True" VerticalAlignment="Center" />
                                </WrapPanel>
                                <GroupBox Header="Customer Dynamic Fields" Margin="0,0,0,6">
                                    <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="spCustomerDynamicFields" Margin="8,4,8,8" />
                                    </ScrollViewer>
                                </GroupBox>
                                <WrapPanel>
                                    <Button Content="New" Width="90" Margin="0,0,8,0" Click="NewCustomer_Click" />
                                    <Button Content="Save" Width="90" Margin="0,0,8,0" Click="SaveCustomer_Click" />
                                    <Button Content="Delete" Width="90" Click="DeleteCustomer_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="Stock Adjustment" Grid.Row="2" Grid.ColumnSpan="2">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="cbAdjustProduct" Grid.Column="0" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,0,8,0" />
                            <TextBlock Grid.Column="1" Text="Qty +/-" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBox x:Name="txtAdjustQty" Grid.Column="2" Width="90" Margin="0,0,8,0" Text="0" />
                            <TextBox x:Name="txtAdjustUnitCost" Grid.Column="3" Width="100" Margin="0,0,8,0" Text="0" />
                            <TextBox x:Name="txtAdjustNote" Grid.Column="4" Margin="0,0,8,0" />
                            <Button Grid.Column="5" Width="120" Content="Adjust Stock" Click="AdjustStock_Click" />
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Import CSV">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border BorderThickness="1" BorderBrush="#DDD" Padding="10" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Products CSV columns: Sku, Name, Unit, SellPrice, CostPrice, TaxRate" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Button Content="Import Products CSV" Width="180" Click="ImportProducts_Click" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" BorderThickness="1" BorderBrush="#DDD" Padding="10" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Customers CSV columns: Code, Name, TaxId, Phone, Email, Address" VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Button Content="Import Customers CSV" Width="180" Click="ImportCustomers_Click" />
                        </StackPanel>
                    </Border>

                    <GroupBox Grid.Row="2" Header="Import Log">
                        <TextBox x:Name="txtImportLog" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" AcceptsReturn="True" />
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <GroupBox Header="Dynamic Fields">
                        <Grid Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <WrapPanel Margin="0,0,0,8">
                                <TextBlock Text="Entity" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <ComboBox x:Name="cbDynamicEntity" Width="140" Margin="0,0,8,0" SelectionChanged="CbDynamicEntity_SelectionChanged" />
                                <Button Content="Reload" Width="90" Margin="0,0,8,0" Click="ReloadDynamicFields_Click" />
                                <Button Content="New" Width="90" Margin="0,0,8,0" Click="NewDynamicField_Click" />
                                <Button Content="Save Field" Width="100" Margin="0,0,8,0" Click="SaveDynamicField_Click" />
                                <Button Content="Delete Field" Width="100" Click="DeleteDynamicField_Click" />
                            </WrapPanel>

                            <DataGrid x:Name="dgDynamicFields" Grid.Row="1" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="DgDynamicFields_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" />
                                    <DataGridTextColumn Header="Key" Binding="{Binding FieldKey}" Width="150" />
                                    <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="*" />
                                    <DataGridTextColumn Header="Type" Binding="{Binding DataType}" Width="90" />
                                    <DataGridCheckBoxColumn Header="Req" Binding="{Binding IsRequired}" Width="60" />
                                    <DataGridCheckBoxColumn Header="Visible" Binding="{Binding IsVisible}" Width="70" />
                                    <DataGridCheckBoxColumn Header="PDF" Binding="{Binding ShowInPdf}" Width="60" />
                                    <DataGridTextColumn Header="Sort" Binding="{Binding SortOrder}" Width="80" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <WrapPanel Grid.Row="2" Margin="0,8,0,0">
                                <TextBox x:Name="txtDynKey" Width="150" Margin="0,0,6,0" />
                                <TextBox x:Name="txtDynLabel" Width="220" Margin="0,0,6,0" />
                                <ComboBox x:Name="cbDynDataType" Width="110" Margin="0,0,6,0" />
                                <TextBox x:Name="txtDynSort" Width="70" Margin="0,0,6,0" Text="0" />
                                <CheckBox x:Name="chkDynRequired" Content="Required" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <CheckBox x:Name="chkDynVisible" Content="Visible" IsChecked="True" Margin="0,0,8,0" VerticalAlignment="Center" />
                                <CheckBox x:Name="chkDynPdf" Content="Show in PDF" VerticalAlignment="Center" />
                            </WrapPanel>
                        </Grid>
                    </GroupBox>

                    <Separator Grid.Row="1" Margin="0,10" />

                    <GroupBox Grid.Row="2" Header="Backup and Reset">
                        <StackPanel Orientation="Horizontal" Margin="8">
                            <Button Content="Export Backup JSON" Width="170" Margin="0,0,8,0" Click="ExportBackup_Click" />
                            <Button Content="Import Backup JSON" Width="170" Margin="0,0,8,0" Click="ImportBackup_Click" />
                            <Button Content="Hard Reset (Backup First)" Width="200" Click="HardReset_Click" />
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
